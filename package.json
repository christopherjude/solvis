{
  "name": "solvis",
  "version": "0.0.0",
  "private": true,
  "description": "Static AWS CloudFormation solution visualizer — interactive diagram of resources, data flows, and permissions.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
